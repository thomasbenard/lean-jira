    plugins: [{
      id: "pctLines",
      afterDraw: function(chart) {
        const ctx2 = chart.ctx, chartArea = chart.chartArea, scales = chart.scales;
        const lines = [
          { v: CYCLE_STATS.median, label: "P50", color: "#10b981" },
          { v: CYCLE_STATS.p85, label: "P85", color: "#f59e0b" },
          { v: CYCLE_STATS.p95, label: "P95", color: "#ef4444" },
        ];
        const binWidth = HISTOGRAM[0].end - HISTOGRAM[0].start;
        ctx2.save();
        ctx2.setLineDash([4, 4]);
        ctx2.font = "11px sans-serif";
        for (const l of lines) {
          const idx = l.v / binWidth - 0.5;
          if (idx < 0 || idx > HISTOGRAM.length) continue;
          const x = scales.x.getPixelForValue(idx);
          ctx2.strokeStyle = l.color;
          ctx2.beginPath();
          ctx2.moveTo(x, chartArea.top);
          ctx2.lineTo(x, chartArea.bottom);
          ctx2.stroke();
          ctx2.fillStyle = l.color;
          ctx2.fillText(l.label + " " + l.v.toFixed(1) + "j", x + 4, chartArea.top + 12);
        }
        ctx2.restore();
      },
    }],
  });
})();

