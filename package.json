{
  "name": "lean-jira",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "sync": "ts-node src/main.ts sync",
    "metrics": "ts-node src/main.ts metrics",
    "metrics:raw": "ts-node src/main.ts metrics --include-outliers",
    "snapshots": "ts-node src/main.ts snapshots",
    "report": "ts-node src/main.ts report",
    "refresh": "npm run sync && npm run snapshots && npm run report",
    "autoconfig": "ts-node src/main.ts autoconfig",
    "validate": "ts-node src/main.ts validate-config",
    "build": "tsc",
    "start": "node dist/main.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix"
  },
  "lint-staged": {
    "src/**/*.ts": "eslint --max-warnings 0"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "axios": "^1.15.2",
    "better-sqlite3": "^12.9.0",
    "commander": "^14.0.3",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.6.0",
    "eslint": "^10.3.0",
    "lint-staged": "^16.4.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1",
    "vitest": "^4.1.5"
  }
}
